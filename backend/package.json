{
  "name": "myde-whatsapp-ai-backend",
  "version": "1.0.0",
  "description": "Atendimento WhatsApp com IA — NestJS + Drizzle + SQS (modo híbrido real/simulado)",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nest build && tsc-alias -p tsconfig.build.json",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:api": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "dev:api": "ts-node -r tsconfig-paths/register src/main.ts",
    "dev:worker": "ts-node -r tsconfig-paths/register src/worker.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "ts-node -r tsconfig-paths/register src/db/migrate.ts",
    "db:seed": "ts-node -r tsconfig-paths/register src/db/seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.668.0",
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/throttler": "^6.5.0",
    "drizzle-orm": "^0.36.0",
    "helmet": "^8.2.0",
    "nestjs-pino": "^4.1.0",
    "openai": "^4.67.3",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.2.2",
    "postgres": "^3.4.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.4",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.28.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
